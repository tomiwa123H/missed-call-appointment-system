/* LOGIN FORM */
.login_container_row {
    display: flex;
    justify-content: center;
    margin: 60px 0;
}

.form-box {
    background: #f4f4f1;
    padding: 40px;
    border-radius: 16px;
    width: 360px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
}

.form-box label {
    font-weight: 600;
    display: block;
    margin-top: 15px;
}

.form-box input {
    width: 100%;
    padding: 10px;
    margin-top: 6px;
    border-radius: 6px;
    border: 1px solid #bbb;
}

.form-box button {
    margin-top: 25px;
    width: 100%;
    padding: 12px;
    background: #c6d083;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
}

.form-box button:hover {
    background: #b8c870;
}

/* INFO SECTION */
.producer-info {
    text-align: center;
    margin-bottom: 60px;
}

.producer-info h3 {
    margin-bottom: 10px;
}

.producer-info p {
    max-width: 500px;
    margin: 0 auto 15px auto;
    color: #444;
}

.contact-btn {
    display: inline-block;
    padding: 10px 20px;
    background: #6c7a2b;
    color: white;
    border-radius: 20px;
    text-decoration: none;
    font-weight: 600;
}

.contact-btn:hover {
    background: #55611f;
}
