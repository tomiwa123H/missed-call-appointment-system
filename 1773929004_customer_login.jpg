/* ============================================
   NAVBAR CONTAINER (CLEAN + MODERN)
============================================ */
.nav-container {
  width: 100%;
  height: 70px;
  background: #c9d28f;
  padding: 0 40px;

  display: flex;
  align-items: center;
  justify-content: flex-start;

  gap: 80px;                     /* spacing between logo + links */
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;

  font-family: "Ponta", sans-serif;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

/* ============================================
   LOGO LEFT
============================================ */
/* ===========================
   LEFT LOGO (IMAGE VERSION)
=========================== */

.nav-left {
    flex-shrink: 0;          /* stops it from stretching */
    display: flex;
    align-items: center;
}

.nav-logo-img {
    height: 70px;            /* 🔥 perfect size for navbars */
    width: auto;
    display: block;
}

.nav-logo-img:hover {
    opacity: 0.8;
    transition: 0.25s ease;
}


/* ============================================
   CENTER GROUP (HOME/PRODUCTS/CONTACT/LOGIN/SIGNUP)
============================================ */
.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 28px;
}

/* BASE NAV LINK */
.nav-link {
  text-decoration: none;
  color: #2a2a2a;
  font-size: 1.05rem;
  font-weight: 500;
  transition: color .25s ease, opacity .25s ease;
}

.nav-link:hover {
  opacity: 0.6;
}

/* ============================================
   BUTTON LINKS (Login / Logout / Dashboard)
============================================ */
.nav-btn {
  padding: 6px 14px;
  border-radius: 6px;
  transition: background .25s ease, color .25s ease, opacity .25s ease;
}

.nav-btn:hover {
  background: rgba(0,0,0,0.08);
}

/* ============================================
   SIGN UP BUTTON (STRONG CTA)
============================================ */
.nav-signup {
  background: #1d1d1d;
  color: #ffffff !important;
  font-weight: 600;
  padding: 6px 18px;
  border-radius: 6px;
  transition: background .25s ease, transform .25s ease;
}

.nav-signup:hover {
  background: #333;
  transform: translateY(-2px);  /* lift effect */
}

/* ============================================
   DIVIDER
============================================ */
.divider {
  opacity: .45;
  font-weight: 600;
}

/* ============================================
   MOBILE
============================================ */
@media (max-width: 760px) {
  .nav-container {
    flex-direction: column;
    height: auto;
    padding: 20px;
    gap: 15px;
  }

  .nav-center {
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }
}